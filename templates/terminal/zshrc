# ~/.zshrc — interactive shells only. Managed template:
# macos-ubuntu-bootstrap (templates/terminal/zshrc).
# Architecture: agent gate first, cached compinit, antidote static plugins,
# deferred tool inits, syntax highlighting last. Target: <50 ms to prompt.

# ── 1. Agent gate ────────────────────────────────────────────────────────────
# Harness markers: Claude Code sets CLAUDECODE; Codex sets CODEX_THREAD_ID /
# CODEX_SANDBOX; Cursor/Gemini legacy markers kept for safety. agy and mimo
# expose no stable marker — the interactive check catches them and any future
# harness. Agents get plain pipes: no pagers, no prompt, no history hooks,
# no frecency pollution.
_is_agent() {
  [[ -n $CLAUDECODE || -n $CODEX_THREAD_ID || -n $CODEX_SANDBOX \
     || -n $CURSOR_AGENT || -n $GEMINI_CLI ]] || [[ ! -o interactive ]]
}
if _is_agent; then
  export PAGER=cat GIT_PAGER=cat GH_PAGER=cat DELTA_PAGER=cat
  export LESS='-FRX' SYSTEMD_PAGER='' GIT_EDITOR=true
  return
fi

# ── 2. History (atuin owns interactive history; these are the fallbacks) ────
HISTFILE="$HOME/.zsh_history"
HISTSIZE=200000
SAVEHIST=200000
setopt SHARE_HISTORY HIST_IGNORE_ALL_DUPS HIST_REDUCE_BLANKS HIST_VERIFY

# ── 3. Completion: full compinit at most once per 24h, else cached ──────────
autoload -Uz compinit
if [[ -n $HOME/.zcompdump(#qNmh-24) ]]; then
  compinit -C
else
  compinit
fi
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$HOME/.zcompcache"
zstyle ':completion:*' menu no            # fzf-tab replaces the menu

# ── 4. Plugins via antidote (offline static bundle) ─────────────────────────
# The installer pre-clones every plugin at its pinned SHA and compiles
# ~/.zsh_plugins.zsh; sourcing that compiled file is pure `source`/`fpath` with
# zero network and no antidote runtime. If the compiled bundle is absent we start
# with NO plugins and fail closed — we never invoke antidote's network loader at
# startup, because it resolves/clones plugins over the network during shell init.
# Re-run the bootstrap to (re)materialize the offline bundle.
if [[ -r "${ZDOTDIR:-$HOME}/.zsh_plugins.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zsh_plugins.zsh"
else
  print -u2 "rldyour: ~/.zsh_plugins.zsh not materialized — starting without plugins (offline fail-closed); re-run the bootstrap to compile the pinned plugin bundle."
fi

# ── 5. Tool inits (zsh-defer, loaded via plugins, keeps prompt instant) ─────
(( $+functions[zsh-defer] )) || zsh-defer() { "$@" }   # fallback: run inline
command -v zoxide  >/dev/null && zsh-defer eval "$(zoxide init zsh)"
command -v atuin   >/dev/null && zsh-defer eval "$(atuin init zsh --disable-up-arrow)"
command -v carapace >/dev/null && zsh-defer eval "$(carapace _carapace zsh)"

# ── 6. Prompt ────────────────────────────────────────────────────────────────
command -v starship >/dev/null && eval "$(starship init zsh)"

# ── 7. Aliases & abbreviations (zsh-abbr gives fish-style expansion) ────────
# This section only runs AFTER the section-1 agent gate; zsh never reads
# .zshrc for non-interactive shells at all. Agents get the tools on PATH
# under their own names. Shadowing policy (2026-07 verdicts):
#   alias = view-layer, argument-compatible supersets only (ls, cat, tree),
#           and only when the replacement executable is available.
#   abbr  = replacements that expand VISIBLY before execution.
#   never = grep, sed, awk, find, jq (rg is deliberately non-POSIX and skips
#           ignored/hidden files; sd cannot host sed one-liners).
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --group-directories-first'
  alias ll='eza -la --git --group-directories-first'
  alias tree='eza --tree'
fi
if command -v bat >/dev/null 2>&1; then
  alias cat='bat'
elif command -v batcat >/dev/null 2>&1; then
  # Ubuntu packages bat as `batcat` to avoid a historical name collision.
  alias cat='batcat'
fi
command -v lazygit >/dev/null 2>&1 && alias lg='lazygit'
# Harness launchers cl / cx / oc are real executables in ~/.local/bin
# (installed by rldyour-ai-cli-tools) — not aliases, so agents can exec them.
if command -v abbr >/dev/null; then
  if command -v git >/dev/null 2>&1; then
    abbr -S -qq gs='git status'     2>/dev/null
    abbr -S -qq gd='git diff'       2>/dev/null
  fi
  command -v difft >/dev/null 2>&1 && abbr -S -qq dft='difft' 2>/dev/null
  command -v jaq >/dev/null 2>&1 && abbr -S -qq jql='jaq' 2>/dev/null
  # 2026-07 modern-unix wave — human shells only, visible expansion
  command -v dust >/dev/null 2>&1 && abbr -S -qq du='dust' 2>/dev/null
  command -v dua >/dev/null 2>&1 && abbr -S -qq dui='dua i' 2>/dev/null
  command -v duf >/dev/null 2>&1 && abbr -S -qq df='duf' 2>/dev/null
  command -v procs >/dev/null 2>&1 && abbr -S -qq ps='procs' 2>/dev/null
  if command -v btop >/dev/null 2>&1; then
    abbr -S -qq top='btop'          2>/dev/null
    abbr -S -qq htop='btop'         2>/dev/null
  fi
  command -v doggo >/dev/null 2>&1 && abbr -S -qq dig='doggo' 2>/dev/null
  command -v gping >/dev/null 2>&1 && abbr -S -qq ping='gping' 2>/dev/null
  command -v hexyl >/dev/null 2>&1 && abbr -S -qq xxd='hexyl' 2>/dev/null
  command -v viddy >/dev/null 2>&1 && abbr -S -qq watch='viddy' 2>/dev/null
fi

# ── 8. fzf keybindings (Ctrl-R handled by atuin; keep Ctrl-T / Alt-C) ───────
for _fzf in \
  /opt/homebrew/opt/fzf/shell/key-bindings.zsh \
  /usr/local/opt/fzf/shell/key-bindings.zsh \
  /usr/share/doc/fzf/examples/key-bindings.zsh; do
  [[ -r $_fzf ]] && { source "$_fzf"; break; }
done
unset _fzf
if command -v fd >/dev/null 2>&1; then
  export FZF_DEFAULT_COMMAND='fd --type f --hidden --exclude .git'
elif command -v fdfind >/dev/null 2>&1; then
  # Ubuntu packages fd as `fdfind`; keep fzf usable without an unmanaged shim.
  export FZF_DEFAULT_COMMAND='fdfind --type f --hidden --exclude .git'
fi
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse'
