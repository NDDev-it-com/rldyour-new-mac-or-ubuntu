{
  "schema_version": 2,
  "adapter": {
    "id": "macos-ubuntu-bootstrap",
    "version": "1.0.0"
  },
  "verified_on": "2026-07-10",
  "targets": {
    "macos": {
      "architectures": [
        "arm64"
      ],
      "profile": "desktop",
      "gui_modes": [
        "enabled",
        "disabled"
      ],
      "docker_modes": [
        "none"
      ],
      "execution_policy": "source-lsp-only"
    },
    "ubuntu": {
      "releases": [
        "24.04",
        "26.04"
      ],
      "architectures": [
        "amd64",
        "arm64"
      ],
      "profiles": {
        "desktop": {
          "gui_modes": [
            "enabled",
            "disabled"
          ],
          "docker_modes": [
            "none"
          ],
          "execution_policy": "source-lsp-only"
        },
        "server": {
          "gui_modes": [
            "disabled"
          ],
          "docker_modes": [
            "none",
            "rootful",
            "rootless"
          ],
          "default_docker_mode": "rootful",
          "execution_policy": "container-execution-only"
        }
      }
    }
  },
  "harnesses": {
    "policy": "one-owner-per-harness",
    "active": [
      "codex",
      "zcode"
    ],
    "codex": {
      "owner_module": "nddev-codex-app",
      "module_path_env": "RLDYOUR_CODEX_MODULE",
      "default_setup": "safe"
    },
    "zcode": {
      "owner_module": "nddev-zcode-app",
      "module_path_env": "RLDYOUR_ZCODE_MODULE",
      "default_setup": "nddev-builder"
    }
  },
  "runtime_support": {
    "ubuntu_node_lts": "24.18.0",
    "ubuntu_node_sha256": {
      "x64": "55aa7153f9d88f28d765fcdad5ae6945b5c0f98a36881703817e4c450fa76742",
      "arm64": "58c9520501f6ae2b52d5b210444e24b9d0c029a58c5011b797bc1fe7105886f6"
    },
    "ubuntu_uv": "0.11.30",
    "ubuntu_uv_sha256": {
      "x64": "04bc7d180d6138bf6dc08387acf507a823f397a98fea55da36b0ccc7fbce3b68",
      "arm64": "8c11d90f5f66d232930cf8ae3a085c39877690d409e10878234802b028b20e2a"
    },
    "ubuntu_bun": "1.3.14",
    "ubuntu_bun_sha256": {
      "x64": "951ee2aee855f08595aeec6225226a298d3fea83a3dcd6465c09cbccdf7e848f",
      "x64-baseline": "a063908ae08b7852ca10939bbdc6ceed3ddabce8fb9402dce83d65d73b36e6c7",
      "arm64": "a27ffb63a8310375836e0d6f668ae17fa8d8d18b88c37c821c65331973a19a3b"
    },
    "purpose": "ai-cli-and-language-server-host-only",
    "managed_receipt": "ubuntu-runtime-v1"
  },
  "browser_automation": {
    "required": true,
    "provider": "cloakbrowser",
    "cloakbrowser": "0.4.10",
    "cdp_endpoint": "http://127.0.0.1:9222",
    "fallback_allowed": false,
    "chrome_devtools_mcp": "1.6.0",
    "playwright_cli": "0.1.17",
    "active_providers": [
      "playwright-cli",
      "chrome-devtools-mcp"
    ],
    "webwright_status": "retired-fail-closed",
    "webwright_enabled": false,
    "disabled_wrapper": "webwright"
  },
  "gui": {
    "macos": [
      "cmux",
      "chatgpt",
      "codex-app",
      "claude-desktop"
    ],
    "ubuntu": []
  },
  "supply_chain": {
    "homebrew_pkg_version": "6.0.9",
    "homebrew_pkg_sha256": "525599bd2dcbda29857120234336b0103ad5283a3dc8511f72066eeb917abd3c",
    "homebrew_installer_team": "927JGANW46",
    "rtk_artifact_version": "0.43.0",
    "rtk_macos_arm64_sha256": "8a17e49acbd378997eb21d0eb6f7f861111f35b4fc9b1c74edf4c7448e576c65",
    "rtk_linux_x64_sha256": "ff8a1e7766496e175291a85aeca1dc97c9ff6df33e51e5893d1fbc78fea2a609",
    "rtk_linux_arm64_sha256": "5519f7ca12e5c143a609f0d28a0a77b97413a8dce31c2681f1a41c24519a8731",
    "browser_provider_lock": "templates/browser/provider/bun.lock",
    "cloakbrowser_lock": "templates/browser/cloakbrowser-uv.lock"
  },
  "safety": {
    "default_mode": "plan",
    "ubuntu_profile_selection": "explicit",
    "browser_unmanaged_files": "preserve-and-fail",
    "system_configuration": "backup-validate-rollback",
    "credentials": "manual-handoff-only",
    "desktop_local_runtime": false,
    "server_firewall_mutation": "explicit-only",
    "server_ssh_hardening": "explicit-only",
    "docker_group_membership": "never-automatic",
    "package_upgrade": "never-automatic",
    "ubuntu_full_apply_user": "non-root-sudo-account",
    "ssh_match_validation": "full-live-connection-context",
    "ufw_cidr_operator_preflight": "required"
  }
}
